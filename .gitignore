# =============================================================================
# Model files - never commit (multi-GB)
# =============================================================================
models/
*.safetensors
*.gguf
*.bin
*.pt
*.pth
*.onnx

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
env/
.venv/
.env/

# =============================================================================
# Docker / runtime artifacts
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# vLLM / HuggingFace caches if anyone accidentally points them here
# =============================================================================
.cache/
hf_cache/
vllm_cache/
*.lock

# =============================================================================
# Logs and runtime output
# =============================================================================
*.log
logs/
nohup.out

# =============================================================================
# Editor / OS junk
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Secrets - belt and suspenders
# =============================================================================
.env
.env.local
*.pem
*.key
secrets/

